{
  "manifest_version": 3,
  "name": "PagePen - Web Annotator & Screenshot",
  "version": "1.1.1",
  "description": "Draw, highlight, annotate and screenshot any webpage with freehand pen, shapes, text, arrows and a color picker.",
  "minimum_chrome_version": "102",
  "homepage_url": "https://github.com/",
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_icon": "icon.png",
    "default_title": "PagePen - Draw & Annotate"
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "permissions": ["activeTab", "scripting", "downloads"]
}
