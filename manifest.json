{
  "manifest_version": 3,
  "name": "DrawLite - Draw & Annotate on Web",
  "version": "1.0.0",
  "description": "Draw, highlight, annotate and screenshot any webpage. Freehand pen, shapes, text, color picker and more.",
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["style.css"]
    }
  ],
  "action": {
    "default_icon": "icon.png"
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "permissions": ["activeTab", "storage", "tabs"]
}
